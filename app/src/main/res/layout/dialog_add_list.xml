<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_list.xml
    Dialog tạo TodoList mới: nhập tên + chọn icon từ RecyclerView lưới.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical">

    <!-- ── Header ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_header"
        android:gravity="center"
        android:padding="18dp"
        android:text="@string/add_list_dialog_title"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- ── Body ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="4dp">

        <!-- Tên danh sách -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_list_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/add_list_hint_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_list_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:imeOptions="actionDone"
                tools:text="My List" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label chọn icon -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/add_list_label_icon"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- RecyclerView lưới icon (3 cột) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_icon_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_icon_picker" />

    </LinearLayout>

    <!-- ── Divider ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/divider" />

    <!-- ── Action buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_add_list_cancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/add_list_btn_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/btn_add_list_create"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/add_list_btn_create"
            android:textColor="@color/priority_low"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>

