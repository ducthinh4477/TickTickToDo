<?xml version="1.0" encoding="utf-8"?>
<!--
  bottom_sheet_day_detail.xml
  BottomSheet hiển thị danh sách task của một ngày cụ thể khi bấm vào ô ngày.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_surface"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@color/divider" />

    <!-- Header: ngày được chọn + số task -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_detail_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Thứ Ba, 16 tháng 3 năm 2025" />

            <TextView
                android:id="@+id/tv_detail_task_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                tools:text="2 công việc" />

        </LinearLayout>

        <!-- Nút thêm task cho ngày này -->
        <ImageButton
            android:id="@+id/btn_add_task_for_day"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_add"
            android:contentDescription="@string/cal_add_event_desc"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent_primary" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="4dp" />

    <!-- Danh sách task (chiều cao tối đa ~50% màn hình) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_day_tasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        tools:listitem="@layout/item_task" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_day_empty"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calendar_empty_message"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
