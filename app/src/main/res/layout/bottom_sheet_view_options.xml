<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- ══════ Drag handle ══════ -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- ══════ View Mode Header ══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- List View -->
        <LinearLayout
            android:id="@+id/btn_view_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_view_mode_selected"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/icon_view_list"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_view_list"
                android:contentDescription="@string/view_mode_list"
                tools:tint="@color/accent_primary" />

            <TextView
                android:id="@+id/label_view_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/view_mode_list"
                android:textColor="@color/accent_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Kanban View -->
        <LinearLayout
            android:id="@+id/btn_view_kanban"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/icon_view_kanban"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_view_kanban"
                android:contentDescription="@string/view_mode_kanban"
                tools:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/label_view_kanban"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/view_mode_kanban"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Timeline View -->
        <LinearLayout
            android:id="@+id/btn_view_timeline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/icon_view_timeline"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_view_timeline"
                android:contentDescription="@string/view_mode_timeline"
                tools:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/label_view_timeline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/view_mode_timeline"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════ Divider 1 ══════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@color/divider" />

    <!-- ══════ Menu Items ══════ -->

    <!-- Hide Completed -->
    <LinearLayout
        android:id="@+id/item_hide_completed"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_hide_completed"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tv_hide_completed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/option_hide_completed"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Show Details -->
    <LinearLayout
        android:id="@+id/item_show_details"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_show_details"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/option_show_details"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- View Options (Sort by / Group by) -->
    <LinearLayout
        android:id="@+id/item_view_options"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_view_options"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/option_view_options"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- ══════ Divider 2 ══════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@color/divider" />

    <!-- Add Section -->
    <LinearLayout
        android:id="@+id/item_add_section"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_add_section"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/option_add_section"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- List Activities -->
    <LinearLayout
        android:id="@+id/item_list_activities"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_list_activities"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/option_list_activities"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>







