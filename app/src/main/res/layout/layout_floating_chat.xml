<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="16dp"
    android:background="@android:color/white"
    android:elevation="12dp"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Assistant"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/btn_toggle_debug_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_close_chat"
            android:layout_marginEnd="10dp"
            android:background="#E8EEF8"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="Hiện Trace"
            android:textColor="#1A3B66"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/btn_close_chat"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#DDDDDD" />

    <LinearLayout
        android:id="@+id/layout_agent_debug_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="#0E1A2A"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Agent Tool Trace"
                android:textColor="#D5E3F7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_clear_debug_trace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Clear"
                android:textColor="#9BC2FF"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/sv_agent_debug_trace"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="6dp"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tv_agent_debug_trace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Chưa có trace."
                android:textColor="#E9F2FF"
                android:textIsSelectable="true"
                android:textSize="11sp" />
        </ScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_floating_chat_messages"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#F6F6F6"
        android:padding="6dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/layout_daily_review_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#EEF3FF"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_daily_review_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#222222"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_move_unfinished_tasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chuyển việc dang dở sang ngày mai" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_message_floating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nhập lệnh..."
            android:background="#F0F0F0"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btn_mic_floating"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btn_send_floating"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginStart="4dp" />
    </LinearLayout>
</LinearLayout>