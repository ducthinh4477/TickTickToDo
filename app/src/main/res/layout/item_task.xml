<?xml version="1.0" encoding="utf-8"?>
<!-- UpTodo-style dark card task item -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_task_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="16dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:rippleColor="#1AFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Checkbox -->
        <CheckBox
            android:id="@+id/cb_task_completed"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:button="@null"
            android:background="@drawable/checkbox_square_selector"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Design meeting with team" />

        <!-- Time -->
        <TextView
            android:id="@+id/tv_task_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_task_title"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            tools:text="14:00" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_task_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
            app:layout_constraintStart_toEndOf="@id/tv_task_time"
            app:layout_constraintTop_toBottomOf="@id/tv_task_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_task_time"
            tools:text="Discuss Room Database"
            tools:visibility="visible" />

        <!-- Priority flag -->
        <ImageView
            android:id="@+id/iv_priority_flag"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/priority_flag_desc"
            android:src="@drawable/ic_flag"
            app:layout_constraintBottom_toBottomOf="@id/tv_task_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_task_title"
            app:tint="@color/priority_none" />

        <LinearLayout
            android:id="@+id/layout_task_attachments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toBottomOf="@id/tv_task_time">

            <ImageView
                android:id="@+id/iv_task_attachment_image"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_dialog_rounded"
                android:contentDescription="@string/detail_attachment_image_desc"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_task_attachment_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dialog_rounded"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="File: assignment.pdf" />

            <TextView
                android:id="@+id/tv_task_attachment_voice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_rounded"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Audio: note.m4a" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_task_subtasks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toBottomOf="@id/layout_task_attachments">

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
