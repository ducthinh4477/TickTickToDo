<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_task_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <!-- ── Checkbox hình tròn (bên trái) ── -->
    <CheckBox
        android:id="@+id/cb_task_completed"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:button="@drawable/checkbox_circle_selector"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_task_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_task_title" />

    <!-- ── Title ── -->
    <TextView
        android:id="@+id/tv_task_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
        app:layout_constraintStart_toEndOf="@id/cb_task_completed"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Họp nhóm dự án Android" />

    <!-- ── Subtitle: Description / Due date ── -->
    <TextView
        android:id="@+id/tv_task_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
        app:layout_constraintStart_toEndOf="@id/cb_task_completed"
        app:layout_constraintTop_toBottomOf="@id/tv_task_title"
        tools:text="Thảo luận về Room Database ∙ 14:00"
        tools:visibility="visible" />

    <!-- ── Priority flag icon (bên phải) ── -->
    <ImageView
        android:id="@+id/iv_priority_flag"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@string/priority_flag_desc"
        android:src="@drawable/ic_flag"
        app:layout_constraintBottom_toBottomOf="@id/tv_task_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_task_title"
        app:tint="@color/priority_none" />

    <!-- ── Divider ở đáy ── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:layout_marginStart="12dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cb_task_completed"
        app:layout_constraintTop_toBottomOf="@id/tv_task_subtitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
