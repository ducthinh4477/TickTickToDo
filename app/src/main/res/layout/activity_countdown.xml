<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    tools:context=".ui.countdown.CountdownActivity">

    <!-- Back button + Title -->
    <RelativeLayout
        android:id="@+id/countdown_header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingTop="32dp">

        <ImageButton
            android:id="@+id/btn_countdown_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/countdown_back_desc"
            android:src="@drawable/ic_close"
            app:tint="#FFFFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/countdown_title"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Ambient sound button + playing indicator -->
        <LinearLayout
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_ambient_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="♫"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_ambient_sound"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/countdown_sound_desc"
                android:src="@drawable/ic_timer"
                app:tint="#FFFFFFFF" />

        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_timer_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btn_mode_countdown">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_countdown"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đếm ngược"
            android:textColor="#FFFFFFFF"
            app:strokeColor="#50FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_stopwatch"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bấm giờ"
            android:textColor="#FFFFFFFF"
            app:strokeColor="#50FFFFFF" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <!-- Timer circle -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp">

        <!-- Outer glow ring -->
        <View
            android:id="@+id/v_ring_outer"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:alpha="0.18"
            android:background="@drawable/bg_timer_ring_outer" />

        <!-- Dashed ring for stopwatch -->
        <View
            android:id="@+id/v_ring_dashed"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:background="@drawable/bg_timer_ring_dashed" />

        <!-- Main circle -->
        <FrameLayout
            android:layout_width="248dp"
            android:layout_height="248dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_timer_circle">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Countdown text -->
                <TextView
                    android:id="@+id/tv_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="monospace"
                    android:text="25:00"
                    android:textColor="#FFFFFFFF"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    tools:text="25:00" />

                <!-- Status label -->
                <TextView
                    android:id="@+id/tv_timer_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/countdown_status_ready"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- Session counter -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/countdown_session"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_session_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="1"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="48dp">

        <!-- Stop/Reset button -->
        <Button
            android:id="@+id/btn_stop"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_btn_timer_secondary"
            android:enabled="false"
            android:text="@string/countdown_btn_stop"
            android:textColor="#FF4A90D9"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Start/Pause button -->
        <Button
            android:id="@+id/btn_start_pause"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_btn_timer_primary"
            android:text="@string/countdown_btn_start"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

