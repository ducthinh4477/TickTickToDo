<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/white"
    android:orientation="horizontal"
    tools:context=".MainActivity">

    <!-- ══ Column 1: Nav Rail (fixed) ══ -->
    <LinearLayout
        android:id="@+id/nav_rail"
        android:layout_width="56dp"
        android:layout_height="match_parent"
        android:background="#2C2C2C"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/nav_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/nav_avatar_desc"
            android:padding="8dp"
            android:src="@drawable/ic_user" />

        <View android:layout_width="match_parent" android:layout_height="16dp" />

        <ImageButton
            android:id="@+id/nav_task"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_task_desc"
            android:scaleType="centerInside"
            android:src="@drawable/ic_today"
            android:tint="#FFFFFF" />

        <View android:layout_width="match_parent" android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/nav_calendar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_calendar_desc"
            android:scaleType="centerInside"
            android:src="@drawable/ic_calendar"
            android:tint="#B0B0B0" />

        <View android:layout_width="match_parent" android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/nav_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_search_desc"
            android:scaleType="centerInside"
            android:src="@drawable/ic_search"
            android:tint="#B0B0B0" />

    </LinearLayout>

    <!-- ══ Column 2: Menu Box (hidden by default) ══ -->
    <LinearLayout
        android:id="@+id/menuBoxContainer"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:background="#FAFAFA"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@string/nav_avatar_desc"
                android:padding="8dp"
                android:src="@drawable/ic_user" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/nav_guest_user"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="8dp" android:paddingBottom="8dp">

            <LinearLayout android:id="@+id/panel_item_today" android:layout_width="match_parent" android:layout_height="48dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_today" android:tint="@color/priority_low" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/header_today" android:textColor="@color/text_primary" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/panel_item_next7days" android:layout_width="match_parent" android:layout_height="48dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" android:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/menu_next_7_days" android:textColor="@color/text_primary" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/panel_item_inbox" android:layout_width="match_parent" android:layout_height="48dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_all_tasks" android:tint="@color/priority_low" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/panel_inbox" android:textColor="@color/text_primary" android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="8dp" android:paddingBottom="8dp">

            <LinearLayout android:id="@+id/panel_item_completed" android:layout_width="match_parent" android:layout_height="48dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_completed" android:tint="#4CAF50" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/menu_completed" android:textColor="@color/text_primary" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/panel_item_trash" android:layout_width="match_parent" android:layout_height="48dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_delete" android:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/menu_trash" android:textColor="@color/text_primary" android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="16dp" android:paddingTop="12dp" android:paddingBottom="6dp" android:text="@string/nav_lists_title" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_lists_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="12dp">

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="4dp" android:background="#E0E0E0" />

            <LinearLayout android:id="@+id/panel_item_notifications" android:layout_width="match_parent" android:layout_height="44dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_notifications" android:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/nav_notifications" android:textColor="@color/text_primary" android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/panel_item_help" android:layout_width="match_parent" android:layout_height="44dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_help" android:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="@string/nav_help" android:textColor="@color/text_primary" android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══ Column 3: Main Content ══ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingTop="16dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btn_hamburger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_desc"
                android:scaleType="centerInside"
                android:src="@drawable/ic_menu" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_header_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/header_today"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_header_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="Wed, Mar 4" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_sort"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_sort_desc"
                android:scaleType="centerInside"
                android:src="@drawable/ic_sort" />

            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_more_desc"
                android:scaleType="centerInside"
                android:src="@drawable/ic_more_vert" />

        </LinearLayout>

        <!-- RecyclerView + Empty state -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                tools:listitem="@layout/item_task" />

            <LinearLayout
                android:id="@+id/layout_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/empty_state_message"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

            </LinearLayout>

        </FrameLayout>

        <!-- Bottom bar: Quick Add + FAB -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_quick_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="68dp"
                android:layout_marginBottom="12dp"
                android:layout_gravity="center_vertical"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/add_task_desc"
                        android:src="@drawable/ic_add"
                        android:tint="@color/priority_low" />

                    <EditText
                        android:id="@+id/et_quick_add"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/quick_add_hint"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btn_send_task"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/send_task_desc"
                        android:src="@drawable/ic_send"
                        android:visibility="gone"
                        android:tint="@color/priority_low"
                        tools:visibility="visible" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_add_task"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:contentDescription="@string/fab_add_desc"
                android:src="@drawable/ic_add"
                app:backgroundTint="@color/priority_low"
                app:fabSize="mini"
                android:tint="@color/white" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
