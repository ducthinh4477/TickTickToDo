<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_primary"
    tools:context=".ui.task.EisenhowerActivity">

    <!-- ══════════════════════════════════════════
         App Bar wrapped in AppBarLayout for shadow
         ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:background="@color/background_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@color/background_surface">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/tv_eisenhower_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ma trận Eisenhower"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════
         Axis label: top — QUAN TRỌNG
         Styled as a pill label with accent tint
         ══════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_axis_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="10sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        android:textColor="@color/accent_primary"
        android:textStyle="bold"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════ Guidelines for 2×2 grid ══════ -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- ══════════════════════════════════════════
         Q1: Khẩn cấp & Quan trọng — red tint
         DO FIRST
         ══════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quadrant_urgent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#12EF5350"
        app:cardElevation="0dp"
        app:strokeColor="#22EF5350"
        app:strokeWidth="1dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_axis_top"
        app:layout_constraintBottom_toTopOf="@id/guideline_h_50"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Quadrant header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="I"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#EF5350" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khẩn cấp và quan trọng"
                    android:textColor="#EF5350"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/ll_tasks_urgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.core.widget.NestedScrollView>

            <TextView
                android:id="@+id/tv_empty_urgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════
         Q2: Không gấp mà Quan trọng — amber tint
         SCHEDULE
         ══════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quadrant_not_urgent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#12FFCA28"
        app:cardElevation="0dp"
        app:strokeColor="#22FFCA28"
        app:strokeWidth="1dp"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_axis_top"
        app:layout_constraintBottom_toTopOf="@id/guideline_h_50"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="II"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#FFCA28" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không gấp mà quan trọng"
                    android:textColor="#F9A825"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/ll_tasks_not_urgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.core.widget.NestedScrollView>

            <TextView
                android:id="@+id/tv_empty_not_urgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════
         Q3: Khẩn cấp nhưng không quan trọng — indigo tint
         DELEGATE
         ══════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quadrant_normal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#125C6BC0"
        app:cardElevation="0dp"
        app:strokeColor="#225C6BC0"
        app:strokeWidth="1dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="III"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#5C6BC0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khẩn cấp nhưng không quan trọng"
                    android:textColor="#5C6BC0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/ll_tasks_normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.core.widget.NestedScrollView>

            <TextView
                android:id="@+id/tv_empty_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════
         Q4: Không cấp bách & không quan trọng — teal tint
         ELIMINATE
         ══════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quadrant_slow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#1226A69A"
        app:cardElevation="0dp"
        app:strokeColor="#2226A69A"
        app:strokeWidth="1dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="IV"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#26A69A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không cấp bách và không quan trọng"
                    android:textColor="#26A69A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/ll_tasks_slow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.core.widget.NestedScrollView>

            <TextView
                android:id="@+id/tv_empty_slow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════
         Extended FAB — bottom-right
         ══════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_eisenhower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:contentDescription="Thêm task"
        android:src="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="@color/accent_primary"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.FAB.Rounded"/>

</androidx.constraintlayout.widget.ConstraintLayout>
