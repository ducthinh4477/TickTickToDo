<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_primary"
    tools:context=".ui.task.EisenhowerActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tv_eisenhower_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ma trận Eisenhower"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary" />
    </LinearLayout>

    <!-- Axis label: top (importance) -->
    <TextView
        android:id="@+id/tv_axis_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="▲  QUAN TRỌNG"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- Axis label: center horizontal (urgency) -->
    <TextView
        android:id="@+id/tv_axis_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KHẨN CẤP"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="@id/guideline_h_50"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50" />

    <TextView
        android:id="@+id/tv_axis_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KHÔNG KHẨN CẤP"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="@id/guideline_h_50"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Q1: Khẩn cấp và Quan trọng — red tint -->
    <androidx.cardview.widget.CardView
        android:id="@+id/quadrant_urgent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12EF5350"
        app:cardElevation="0dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_axis_top"
        app:layout_constraintBottom_toTopOf="@id/guideline_h_50"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="I"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#EF5350" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khẩn cấp và Quan trọng"
                    android:textColor="#EF5350"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="DO FIRST"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="#EF5350"
                android:alpha="0.7" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:id="@+id/ll_tasks_urgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>
            <TextView
                android:id="@+id/tv_empty_urgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Q2: Không gấp mà quan trọng — blue tint -->
    <androidx.cardview.widget.CardView
        android:id="@+id/quadrant_not_urgent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFCA28"
        app:cardElevation="0dp"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_axis_top"
        app:layout_constraintBottom_toTopOf="@id/guideline_h_50"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="II"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#FFCA28" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không gấp mà quan trọng"
                    android:textColor="#FFCA28"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="SCHEDULE"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="#FFCA28"
                android:alpha="0.7" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:id="@+id/ll_tasks_not_urgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>
            <TextView
                android:id="@+id/tv_empty_not_urgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Q3: Khẩn cấp nhưng không quan trọng — indigo tint -->
    <androidx.cardview.widget.CardView
        android:id="@+id/quadrant_normal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#125C6BC0"
        app:cardElevation="0dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="III"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#5C6BC0" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khẩn cấp nhưng ko q.trọng"
                    android:textColor="#5C6BC0"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="DELEGATE"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="#5C6BC0"
                android:alpha="0.7" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:id="@+id/ll_tasks_normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>
            <TextView
                android:id="@+id/tv_empty_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Q4: Không cấp bách và không quan trọng — teal tint -->
    <androidx.cardview.widget.CardView
        android:id="@+id/quadrant_slow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1226A69A"
        app:cardElevation="0dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_h_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="IV"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    app:backgroundTint="#26A69A" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không cấp bách và ko q.trọng"
                    android:textColor="#26A69A"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="ELIMINATE"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="#26A69A"
                android:alpha="0.7" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:id="@+id/ll_tasks_slow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>
            <TextView
                android:id="@+id/tv_empty_slow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="@string/eisenhower_empty"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Axis label: bottom (not important) -->
    <TextView
        android:id="@+id/tv_axis_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="KHÔNG QUAN TRỌNG  ▼"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Draggable FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_eisenhower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="@color/accent_primary"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
