<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <CheckBox
        android:id="@+id/cb_subtask_done"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:button="@null"
        android:background="@drawable/checkbox_square_selector"
        android:contentDescription="@string/subtask_toggle_complete_desc" />

    <TextView
        android:id="@+id/tv_subtask_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:maxLines="3"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btn_subtask_priority"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/subtask_change_priority_desc"
        android:src="@drawable/ic_flag"
        app:tint="@color/priority_none" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_subtask_approve"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:minWidth="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="@string/subtask_approve"
        android:textAllCaps="false"
        android:textSize="11sp" />

</LinearLayout>