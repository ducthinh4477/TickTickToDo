<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- UpTodo Light Theme -->
    <style name="Base.Theme.TickTickToDo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/accent_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorSurfaceVariant">@color/background_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>
        <!-- Status bar icons tối trên nền sáng -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- Custom CalendarView Style -->
        <item name="android:calendarViewStyle">@style/Widget.TickTickToDo.CalendarView</item>
    </style>

    <style name="Theme.TickTickToDo" parent="Base.Theme.TickTickToDo" />

    <!-- CalendarView date text -->
    <style name="CalendarDateText" parent="android:TextAppearance">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Custom CalendarView Widget Style -->
    <style name="Widget.TickTickToDo.CalendarView" parent="android:Widget.CalendarView">
        <item name="android:dateTextAppearance">@style/CalendarDateText</item>
        <item name="android:weekDayTextAppearance">@style/CalendarDateText</item>
        <item name="android:focusedMonthDateColor">@color/text_primary</item>
        <item name="android:unfocusedMonthDateColor">@color/text_secondary</item>
        <item name="android:selectedWeekBackgroundColor">@color/accent_primary</item>
        <item name="android:weekNumberColor">@color/text_secondary</item>
        <item name="android:weekSeparatorLineColor">@color/divider</item>
    </style>

    <!-- UpTodo Bottom Navigation style -->
    <style name="UpTodoBottomNav">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>

    <!-- BottomSheetDialog style: bo goc, nen surface -->
    <style name="Theme.TickTickToDo.BottomSheetDialog"
        parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TickTickBottomSheet</item>
    </style>

    <style name="TickTickBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/background_surface</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetShapeOverlay</item>
    </style>

    <style name="BottomSheetShapeOverlay">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Theme.TickTickToDo.Translucent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
