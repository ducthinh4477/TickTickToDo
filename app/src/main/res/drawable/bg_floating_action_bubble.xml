<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#4C92F0"
                android:endColor="#285FCE" />
            <stroke
                android:width="1dp"
                android:color="#D0FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#56A3FF"
                android:endColor="#346BE6" />
            <stroke
                android:width="1dp"
                android:color="#A6FFFFFF" />
        </shape>
    </item>
</selector>
