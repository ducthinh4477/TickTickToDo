<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══ Permissions ══ -->
    <!-- Hiển thị notification (bắt buộc từ Android 13 / API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Đặt exact alarm chính xác đến giây (bắt buộc từ Android 12 / API 31) — user phải cấp qua Settings -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Tự động được cấp trên Android 13+ cho ứng dụng lịch/nhắc nhở, không cần user action -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Nhận broadcast khi thiết bị khởi động lại để restore alarm -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Truy cập chính sách Không làm phiền (DND) để thông báo từ app luôn hiển thị -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:name=".TickTickApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TickTickToDo">
        <!-- ══ Splash / Welcome screen — Launcher Activity ══ -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TickTickToDo"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.TaskDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.CountdownActivity"
            android:exported="false" />

        <activity
            android:name=".ui.CalendarActivity"
            android:exported="false" />

        <activity
            android:name=".ui.StatisticsActivity"
            android:exported="false" />

        <!-- TimerService: chạy logic đếm ngược Pomodoro, giao tiếp qua Binder + LocalBroadcast -->
        <service
            android:name=".service.TimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                      android:value="timer_pomodoro" />
        </service>

        <!-- TaskReminderReceiver: nhận Intent từ AlarmManager → hiển thị Notification -->
        <receiver
            android:name=".receiver.TaskReminderReceiver"
            android:exported="false" />

        <!-- NotificationActionReceiver: Handling Quick Actions from Notification -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false" />

        <activity android:name=".ui.SchoolLoginActivity" android:exported="false"/>
        
        <activity android:name=".ui.MoodleActivity" android:exported="false"/>

        <!-- BootReceiver: restore tất cả alarm sau khi thiết bị khởi động lại -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>