<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══ Permissions ══ -->
    <!-- Hiển thị notification (bắt buộc từ Android 13 / API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Đặt exact alarm chính xác đến giây (bắt buộc từ Android 12 / API 31) — user phải cấp qua Settings -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Tự động được cấp trên Android 13+ cho ứng dụng lịch/nhắc nhở, không cần user action -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Nhận broadcast khi thiết bị khởi động lại để restore alarm -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <!-- Truy cập chính sách Không làm phiền (DND) để thông báo từ app luôn hiển thị -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:name=".TickTickApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TickTickToDo">
        <activity
            android:name=".ui.SplashActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo"
            android:noHistory="true" />

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TickTickToDo.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
            
        <activity
            android:name=".ui.activitylog.ActivityLogActivity"
            android:exported="false" />

        <activity
            android:name=".ui.task.TaskDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.countdown.CountdownActivity"
            android:exported="false" />

        <activity
            android:name=".ui.calendar.CalendarActivity"
            android:exported="false" />

        <activity
            android:name=".ui.StatisticsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.habit.HabitTrackerActivity"
            android:exported="false" />

        <!-- TimerService: chạy logic đếm ngược Pomodoro, giao tiếp qua Binder + LocalBroadcast -->
        <service
            android:name=".ui.countdown.TimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                      android:value="timer_pomodoro" />
        </service>

        <!-- TaskReminderReceiver: nhận Intent từ AlarmManager → hiển thị Notification -->
        <receiver
            android:name=".ui.task.TaskReminderReceiver"
            android:exported="false" />

        <!-- NotificationActionReceiver: Handling Quick Actions from Notification -->
        <receiver
            android:name=".ui.task.NotificationActionReceiver"
            android:exported="false" />

        <activity android:name=".ui.SchoolLoginActivity" android:exported="false"/>
        
        <activity android:name=".ui.MoodleActivity" android:exported="false"/>  

        <activity android:name=".ui.chat.AiAssistantActivity" android:exported="false" android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".ui.chat.ChatHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.debug.ProactiveDebugActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo" />

        <activity
            android:name=".ui.VoicePromptActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo.Translucent" />

        <activity
            android:name=".ui.FloatingQuickAddActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo.Translucent" />

        <receiver
            android:name=".core.background.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Receiver đảm nhiệm việc buộc cập nhật Moodle ngay tức thì -->
        <receiver
            android:name=".ui.moodle.SchoolSyncReceiver"
            android:exported="false" />

        <activity
            android:name=".ui.task.EisenhowerActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo" />
			
        <activity
            android:name=".ui.countdown.EventCountdownActivity"
            android:exported="false"
            android:theme="@style/Theme.TickTickToDo" />

        <service
            android:name=".core.background.FloatingAssistantService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse|microphone">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_assistant_overlay" />
        </service>

        <service
            android:name=".ui.assistant.VoiceTaskTileService"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/ic_add"
            android:label="@string/qs_voice_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>