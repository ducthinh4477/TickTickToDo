<?xml version="1.0" encoding="utf-8"?>
<!--
  bottom_sheet_add_calendar_event.xml
  BottomSheet thêm sự kiện / công việc mới từ Calendar.
  Các field:
    1. Tiêu đề sự kiện
    2. Ngày bắt đầu (click → DatePickerDialog)
    3. Giờ bắt đầu  (click → TimePickerDialog)
    4. Mô tả
    5. Địa điểm
    6. Thời lượng (phút)
    7. Lặp lại (Spinner: không / hàng tuần / hàng tháng)
    8. Hủy / Lưu
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_surface"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@color/divider" />

    <!-- Tiêu đề BottomSheet -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:text="@string/cal_add_event_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- ScrollView bao trọn nội dung form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- ── 1. Tiêu đề sự kiện ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_title"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/cal_event_hint_title"
                app:startIconDrawable="@drawable/ic_flag">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 2. Ngày + Giờ bắt đầu (trên 1 hàng ngang) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Ngày bắt đầu -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_event_date"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:layout_marginEnd="6dp"
                    android:hint="@string/cal_event_hint_date"
                    app:endIconMode="none">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_event_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        tools:text="15/03/2025" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Giờ bắt đầu -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_event_time"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:layout_marginStart="6dp"
                    android:hint="@string/cal_event_hint_time"
                    app:endIconMode="none">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_event_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        tools:text="08:30" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ── 3. Mô tả ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_description"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/cal_event_hint_description">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="2"
                    android:maxLines="4"
                    android:gravity="top|start" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 4. Địa điểm ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_location"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/cal_event_hint_location"
                app:startIconDrawable="@drawable/ic_location">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:imeOptions="actionNext"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 5. Thời lượng (phút) ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_duration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/cal_event_hint_duration"
                app:startIconDrawable="@drawable/ic_timer"
                app:suffixText="@string/cal_event_duration_suffix">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 6. Lặp lại (Spinner) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Icon lặp lại -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_repeat"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cal_event_label_recurrence"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="12dp" />

                <!-- Spinner lặp lại -->
                <Spinner
                    android:id="@+id/spinner_recurrence"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_calendar_cell"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- ── 7. Nút Hủy / Lưu ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_cancel_event"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cal_event_btn_cancel"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_save_event"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cal_event_btn_save"
                    android:backgroundTint="@color/accent_primary" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
