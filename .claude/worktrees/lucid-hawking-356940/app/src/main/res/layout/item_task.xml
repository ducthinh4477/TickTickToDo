<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_task_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:layout_marginHorizontal="16dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:rippleColor="#1AFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Zone 1: Checkbox — 44dp touch target via layout size -->
        <CheckBox
            android:id="@+id/cb_task_completed"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:button="@null"
            android:background="@drawable/checkbox_square_selector"
            android:padding="10dp"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Zone 1: Task title — single line, ellipsize -->
        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="@id/cb_task_completed"
            app:layout_constraintEnd_toStartOf="@id/iv_priority_flag"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toTopOf="@id/cb_task_completed"
            tools:text="Design meeting with team" />

        <!-- Zone 1: Priority flag at end of title row -->
        <ImageView
            android:id="@+id/iv_priority_flag"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/priority_flag_desc"
            android:src="@drawable/ic_flag"
            app:layout_constraintBottom_toBottomOf="@id/tv_task_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_task_title"
            app:tint="@color/priority_none" />

        <!-- Zone 2: Metadata chips row — date, tag, time -->
        <HorizontalScrollView
            android:id="@+id/scroll_task_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:scrollbars="none"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toBottomOf="@id/cb_task_completed">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_task_time"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:text="⏰ 09:00"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_task_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:text="📚 Study"
                    tools:visibility="visible" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Zone 3: Attachments (shown when task has attachments) -->
        <LinearLayout
            android:id="@+id/layout_task_attachments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toBottomOf="@id/scroll_task_meta">

            <ImageView
                android:id="@+id/iv_task_attachment_image"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_dialog_rounded"
                android:contentDescription="@string/detail_attachment_image_desc"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_task_attachment_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dialog_rounded"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="File: assignment.pdf" />

            <TextView
                android:id="@+id/tv_task_attachment_voice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_rounded"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Audio: note.m4a" />

        </LinearLayout>

        <!-- Zone 3: Subtasks (shown when task has subtasks) -->
        <LinearLayout
            android:id="@+id/layout_task_subtasks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cb_task_completed"
            app:layout_constraintTop_toBottomOf="@id/layout_task_attachments" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
