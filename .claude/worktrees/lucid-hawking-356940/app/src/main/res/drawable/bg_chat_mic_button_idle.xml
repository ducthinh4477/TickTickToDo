<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/floating_chat_mic_idle_pressed_bg" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/floating_chat_mic_idle_pressed_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/floating_chat_mic_idle_bg" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/floating_chat_mic_idle_stroke" />
        </shape>
    </item>
</selector>
