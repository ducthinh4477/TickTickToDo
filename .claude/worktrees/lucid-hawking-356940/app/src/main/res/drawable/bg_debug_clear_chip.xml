<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/floating_chat_debug_chip_pressed" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="@color/floating_chat_debug_chip_pressed_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/floating_chat_debug_chip" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="@color/floating_chat_debug_chip_stroke" />
        </shape>
    </item>
</selector>
